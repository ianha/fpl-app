# Root environment template for the FPLytics monorepo.
# Copy this file to `.env` and adjust values as needed.

# API server port
PORT=4000

# SQLite database file used by the API sync and server.
# Optional: leave unset to use the repo-local default.
# Example: DB_PATH=/Users/you/fplytics/apps/api/data/fpl.sqlite

# Directory where downloaded player and team JPEG assets are stored.
# Optional: leave unset to use the repo-local default.
# Example: ASSETS_DIR=/Users/you/fplytics/apps/api/data/assets

# Public FPL API base URL
FPL_BASE_URL=https://fantasy.premierleague.com/api

# FPL website origin used for authenticated My Team session login
FPL_SITE_URL=https://fantasy.premierleague.com

# Minimum interval between outbound FPL requests in milliseconds
FPL_MIN_REQUEST_INTERVAL_MS=3000

# Required to encrypt locally stored FPL OAuth tokens for My Team sync.
# Generate a unique value before linking an account, for example:
# openssl rand -hex 32
# FPL_AUTH_SECRET=

# Public-facing origin for the API server (no trailing slash).
# Used to build absolute URLs in Open Graph meta tags for social sharing.
# Set this in production so share links point to the real domain, not localhost.
# Example: PUBLIC_URL=https://fplytics.example.com
# PUBLIC_URL=

# Public-facing origin for the web app (no trailing slash).
# Used for OAuth redirects back into the SPA.
# Example: WEB_URL=https://fplytics-web.example.com
# WEB_URL=http://localhost:5173

# Frontend API base URL
# Optional: leave unset to use the current site origin + /api.
# Set this only when you explicitly want the frontend to call a different API host.
# VITE_API_BASE_URL=

# Comma-separated hostnames Vite should allow in dev mode.
# Example: VITE_ALLOWED_HOSTS=host.example,another-host.example

# MCP/local tool exposure:
# auto = localhost/private hosts only (default)
# off = disable /mcp entirely
# on = allow non-local /mcp only with FPL_TOOL_AUTH_TOKEN
# FPL_LOCAL_TOOLS=auto
# FPL_TOOL_AUTH_TOKEN=
